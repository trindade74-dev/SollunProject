# 🔐 Environment Variables Template
# Copie este arquivo para .env.local e preencha com suas credenciais

# ===== Google OAuth =====
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ===== OpenAI API =====
OPENAI_API_KEY=sk-proj-your_openai_key_here

# ===== Supabase =====
SUPABASE_HOST=https://your-project.supabase.co
SUPABASE_ROLE_SECRET=your_supabase_service_role_key_here

# ===== Flowengine =====
FLOWENGINE_API_KEY=fe_your_flowengine_key_here

# ===== Ambiente =====
NODE_ENV=development
VITE_API_URL=http://localhost:3000
